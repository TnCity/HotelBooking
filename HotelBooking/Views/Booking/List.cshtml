@model List<HotelBooking.Models.BookingListModel>

@{
    ViewData["Title"] = "All Bookings";
}

<div class="container mt-4">

    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">All Bookings</h2>

        <div>
            <a asp-controller="Booking"
               asp-action="List"
               class="btn btn-outline-dark me-2">
                All Bookings
            </a>

            <a asp-controller="Booking"
               asp-action="FromToday"
               class="btn btn-warning">
                From Today Onwards
            </a>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <table class="table table-bordered table-striped mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th>Booking Id</th>
                        <th>Room Number</th>
                        <th>Customer Name</th>
                        <th>Check-In Date</th>
                        <th>Check-Out Date</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var booking in Model)
                        {
                            <tr class="text-center">
                                <td>@booking.BookingId</td>
                                <td>@booking.RoomNumber</td>
                                <td>@booking.CustomerName</td>
                                <td>@booking.CheckInDate.ToString("dd-MM-yyyy")</td>
                                <td>@booking.CheckOutDate.ToString("dd-MM-yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-danger fw-bold py-3">
                                No bookings found.
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>