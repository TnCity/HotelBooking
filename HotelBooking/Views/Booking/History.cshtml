<!--
PSEUDOCODE / PLAN:
1. On DOMContentLoaded attach click handlers to all ".room-cell".
2. On click:
   a. Read roomId and date from data attributes.
   b. If cell has class "available":
      - Redirect to booking page with roomId and checkIn=date.
      - Return.
   c. If cell has class "booked":
      - Prompt user with confirm: "Are you sure you want to delete booking?"
      - If user cancels: return (do nothing).
      - If user confirms:
         i. Toggle UI to available (remove 'booked', add 'available', set inner HTML).
         ii. Record a change entry (roomId, date, status = "Available") in the 'changes' array (update existing entry if present).
         iii. Immediately call saveChanges() to persist the deletion.
         iv. Return to prevent further handling.
3. saveChanges() will POST the changes array as JSON to /Booking/SaveAvailability and reload on success.
4. Tooltips are initialized on DOM ready as before.
-->

@model HotelBooking.Models.BookingHistoryVM

@{
    ViewData["Title"] = "Booking History";
}

<div class="container mt-4">

    <h2 class="text-center mb-4">Upcoming Booking</h2>

    <!----------------------------------------- DATE RANGE FILTER -------------------------------------------------->

    <form method="get" asp-action="History" class="row g-3 mb-4 align-items-end">

        <div class="col-md-3">
            <label class="form-label fw-bold">From Date</label>
            <input type="date"
                   name="fromDate"
                   value="@ViewBag.FromDate"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">To Date</label>
            <input type="date"
                   name="toDate"
                   value="@ViewBag.ToDate"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">
                🔍 Show Result
            </button>
        </div>

    </form>

    <!-<!------------------------------------------ BOOKING GRID ------------------------------------------->

    <div style="overflow-x:auto;">
        <table class="table table-bordered text-center">
            <thead class="table-success">
                <tr>
                    <th>Room</th>

                    @foreach (var date in Model.Dates)
                    {
                        <th style="min-width:90px;">
                            @date.ToString("dd-MM-yyyy")
                        </th>
                    }

                </tr>
            </thead>

            <tbody>

                @foreach (var room in Model.Rooms)
                {
                    <tr>

                        <td class="fw-bold">
                            @room.RoomNumber
                        </td>

                        @foreach (var date in Model.Dates)
                        {
                            var booking = Model.Booking.FirstOrDefault(b =>
                            b.RoomId == room.RoomId &&
                            date >= b.CheckInDate &&
                            date < b.CheckOutDate
                            );

                            bool isBooked = booking != null;


                            <td class="room-cell @(isBooked ? "booked" : "available")"
                                data-roomid="@room.RoomId"
                                data-date="@date.ToString("yyyy-MM-dd")"
                                data-bs-toggle="tooltip"
                                data-bs-html="true"
                                title="@(isBooked ? $"<b>Customer:</b> {booking.CustomerName}<br><b>CheckIn:</b> {booking.CheckInDate:dd-MM-yyyy}<br><b>CheckOut:</b> {booking.CheckOutDate:dd-MM-yyyy}" : "Available")">

                                @(isBooked ? "✔" : "✖")
                            </td>
                        }

                    </tr>
                }

            </tbody>
        </table>
    </div>

    <!----------------------------------------- SAVE BUTTON ----------------------------------------->

    <div class="d-flex justify-content-end mb-3">
        @* <button class="btn btn-success btn-lg" onclick="saveChanges()">
            Save Changes
        </button> *@
    </div>

</div>

<style>

    .room-cell {
        cursor: pointer;
        font-weight: bold;
    }

        .room-cell.available {
            background-color: #198754 !important;
            color: white;
        }

        .room-cell.booked {
            background-color: #dc3545 !important;
            color: white;
        }

        .room-cell:hover {
            opacity: 0.8;
        }

</style>

<script>

        let changes = [];

        //=====================================================================================================
                                             // for redirect to Booking page
    //===========================================================================================================


    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".room-cell").forEach(cell => {

            cell.addEventListener("click", function () {

                let roomId = this.dataset.roomid;
                let date = this.dataset.date;

                // If cell is available → redirect to booking page
                if (this.classList.contains("available")) {

                    window.location.href =
                        "/Room/Book?roomId=" + roomId + "&checkIn=" + date;

                    return;
                }

                // If already booked → allow toggle (confirm deletion)
                let status;

                if (this.classList.contains("booked")) {

                    // Ask for confirmation before deleting the booking
                    if (!confirm("Are you sure you want to delete booking?")) {
                        return;
                    }

                    this.classList.remove("booked");
                    this.classList.add("available");
                    this.innerHTML = "✖";
                    status = "Available";

                    // Update or add change entry
                    let existing = changes.find(x => x.roomId == roomId && x.date == date);

                    if (existing) {
                        existing.status = status;
                    } else {
                        changes.push({
                            roomId: roomId,
                            date: date,
                            status: status
                        });
                    }

                    // Immediately persist the deletion
                    saveChanges();

                    return;
                }

                let existing = changes.find(x => x.roomId == roomId && x.date == date);

                if (existing) {
                    existing.status = status;
                } else {
                    changes.push({
                        roomId: roomId,
                        date: date,
                        status: status
                    });
                }

            });

        });

    });
